{
  "name": "@hedystia/view",
  "version": "2.3.1",
  "description": "Reactive UI engine — fine-grained signals, no Virtual DOM, real DOM nodes",
  "homepage": "https://docs.hedystia.com",
  "private": false,
  "keywords": [
    "hedystia",
    "view",
    "ui",
    "reactive",
    "signals",
    "typescript",
    "type-safe",
    "jsx"
  ],
  "license": "MIT",
  "type": "commonjs",
  "types": "./dist/index.d.cts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.cts",
      "import": "./dist/jsx-runtime.mjs",
      "require": "./dist/jsx-runtime.cjs"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.cts",
      "import": "./dist/jsx-dev-runtime.mjs",
      "require": "./dist/jsx-dev-runtime.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.cts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.cjs"
    }
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "release:pkg": "bun publish --provenance --access public",
    "dev": "tsdown --watch"
  },
  "peerDependencies": {
    "vite": ">= 7.3.1"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hedystia/Hedystia"
  },
  "author": {
    "name": "Zastinian",
    "email": "contact@zastinian.com",
    "url": "https://github.com/Zastinian"
  }
}
