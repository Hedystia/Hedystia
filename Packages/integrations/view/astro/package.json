{
  "name": "@hedystia/astro",
  "version": "2.3.6",
  "description": "Use @hedystia/view components within Astro",
  "homepage": "https://docs.hedystia.com",
  "private": false,
  "keywords": [
    "hedystia",
    "astro-integration",
    "astro-component",
    "renderer",
    "view"
  ],
  "license": "MIT",
  "type": "commonjs",
  "types": "./dist/index.d.cts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./client.js": {
      "types": "./dist/client.d.cts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.cjs"
    },
    "./server.js": {
      "types": "./dist/server.d.cts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "release:pkg": "bun publish --provenance --access public",
    "dev": "tsdown --watch"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@hedystia/view": ">= 2.0.0",
    "astro": ">= 6.0.0",
    "vite": ">= 7.3.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hedystia/Hedystia"
  },
  "author": {
    "name": "Zastinian",
    "email": "contact@zastinian.com",
    "url": "https://github.com/Zastinian"
  }
}
