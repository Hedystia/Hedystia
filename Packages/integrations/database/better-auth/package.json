{
  "name": "@hedystia/better-auth",
  "version": "2.3.0",
  "description": "@hedystia/db adapter for Better Auth",
  "homepage": "https://docs.hedystia.com",
  "private": false,
  "keywords": [
    "hedystia",
    "better-auth",
    "database",
    "orm",
    "adapter",
    "auth"
  ],
  "license": "MIT",
  "type": "commonjs",
  "types": "./dist/index.d.cts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "release:pkg": "bun publish --provenance --access public",
    "dev": "tsdown --watch"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@hedystia/db": ">= 2.0.0",
    "better-auth": ">= 1.4.19"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hedystia/Hedystia"
  },
  "author": {
    "name": "Zastinian",
    "email": "contact@zastinian.com",
    "url": "https://github.com/Zastinian"
  }
}
