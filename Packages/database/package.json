{
  "name": "@hedystia/db",
  "version": "2.3.5",
  "description": "Next-gen TypeScript ORM for building type-safe database layers at lightspeed",
  "homepage": "https://docs.hedystia.com",
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "mysql2": ">= 3.0.0",
    "mysql": ">= 2.0.0",
    "better-sqlite3": ">= 12.0.0",
    "sqlite3": ">= 6.0.0",
    "sql.js": ">= 1.0.0",
    "pg": ">= 8.0.0",
    "@aws-sdk/client-s3": ">= 3.0.0"
  },
  "peerDependenciesMeta": {
    "mysql2": {
      "optional": true
    },
    "mysql": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "sqlite3": {
      "optional": true
    },
    "sql.js": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "@aws-sdk/client-s3": {
      "optional": true
    }
  },
  "bin": {
    "@hedystia/db": "./dist/cli.mjs"
  },
  "private": false,
  "keywords": [
    "hedystia",
    "database",
    "orm",
    "typescript",
    "type-safe",
    "bun",
    "mysql",
    "sqlite"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "release:pkg": "bun publish --provenance --access public",
    "dev": "tsdown --watch"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hedystia/Hedystia"
  },
  "author": {
    "name": "Zastinian",
    "email": "contact@zastinian.com",
    "url": "https://github.com/Zastinian"
  },
  "type": "commonjs",
  "types": "./dist/index.d.cts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  }
}
