{
  "name": "framework",
  "license": "MIT",
  "homepage": "https://docs.hedystia.com",
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bun": "catalog:",
    "bumpp": "11.0.1",
    "changelogithub": "14.0.0",
    "tinyglobby": "0.2.15",
    "tsdown": "0.22.0",
    "turbo": "2.9.12",
    "typescript": "catalog:",
    "unrun": "0.3.0"
  },
  "workspaces": {
    "packages": [
      "./Packages/adapter",
      "./Packages/types",
      "./Packages/server",
      "./Packages/client",
      "./Packages/websocket",
      "./Packages/swagger",
      "./Packages/validations",
      "./Packages/database",
      "./Packages/view",
      "./Packages/integrations/view/astro",
      "./Packages/integrations/database/better-auth",
      "./Tests"
    ],
    "catalog": {
      "typescript": "6.0.2",
      "@types/bun": "^1.3.11"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test --filter tests",
    "bump": "bumpp -r",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "release": "turbo run release:pkg"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hedystia/Hedystia"
  },
  "author": {
    "name": "Zastinian",
    "email": "contact@zastinian.com",
    "url": "https://github.com/Zastinian"
  },
  "packageManager": "bun@1.3.9"
}
